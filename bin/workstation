#!/usr/bin/env bash
#
# Workstation CLI v3.0 - Secure Organization Manager for OpenClaw
# Simplified, hardened, and agent-native.
#
# Design principles:
# - Git as single source of truth
# - Filesystem as state machine
# - Atomic operations only
# - No eval, no injection vectors
#

set -euo pipefail

# ============================================================================
# CONFIGURATION & CONSTANTS
# ============================================================================

readonly VERSION="3.0.0"
readonly WORKSTATION_ROOT="${WORKSTATION_ROOT:-$HOME/Workstation}"
readonly OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"

# Colors (only if terminal supports it)
if [[ -t 1 ]]; then
  readonly RED='\033[0;31m'
  readonly GREEN='\033[0;32m'
  readonly YELLOW='\033[1;33m'
  readonly BLUE='\033[0;34m'
  readonly NC='\033[0m'
else
  readonly RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

# ============================================================================
# LOGGING
# ============================================================================

log_info() { printf "${BLUE}[INFO]${NC} %s\n" "$1"; }
log_success() { printf "${GREEN}[OK]${NC} %s\n" "$1"; }
log_warn() { printf "${YELLOW}[WARN]${NC} %s\n" "$1"; }
log_error() { printf "${RED}[ERROR]${NC} %s\n" "$1" >&2; }

die() {
  log_error "$1"
  exit "${2:-1}"
}

# ============================================================================
# SECURITY: Input validation and sanitization
# ============================================================================

# Validate and sanitize organization/seat names
# Allowed: lowercase letters, numbers, hyphens. Must start with letter.
validate_id() {
  local id="$1"
  local context="${2:-identifier}"
  
  if [[ -z "$id" ]]; then
    die "$context cannot be empty"
  fi
  
  if [[ ${#id} -gt 64 ]]; then
    die "$context too long (max 64 chars)"
  fi
  
  if [[ ! "$id" =~ ^[a-z][a-z0-9-]*$ ]]; then
    die "Invalid $context '$id'. Must: start with letter, use only lowercase letters, numbers, hyphens"
  fi
  
  # Prevent path traversal
  if [[ "$id" == *".."* || "$id" == *"/"* || "$id" == *"\\"* ]]; then
    die "Invalid $context '$id' contains path separators"
  fi
  
  printf '%s' "$id"
}

# Validate Git URL (basic check for common schemes)
validate_git_url() {
  local url="$1"
  
  if [[ -z "$url" ]]; then
    die "Git URL cannot be empty"
  fi
  
  # Accept file://, https://, http://, git@, or absolute paths
  if [[ ! "$url" =~ ^(file://|https?://|git@|/) ]]; then
    die "Invalid Git URL format: $url"
  fi
  
  printf '%s' "$url"
}

# Escape string for safe use in sed replacements
escape_sed() {
  printf '%s' "$1" | sed 's/[&/\\]/\\&/g'
}

# ============================================================================
# FILESYSTEM UTILITIES
# ============================================================================

# Find SSOT directory by walking up tree
find_ssot() {
  local dir="${1:-$PWD}"
  local original_dir="$dir"
  
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/workstation.json" ]]; then
      printf '%s' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  
  return 1
}

# Get config value from workstation.json (safely)
# Usage: get_config <ssot_dir> [jq_args...] <jq_filter>
get_config() {
  local ssot_dir="$1"
  local json_file="$ssot_dir/workstation.json"
  shift
  # Pass remaining args to jq, with the file at the end
  jq -r "$@" "$json_file" 2>/dev/null || true
}

# Atomic JSON update with file locking
atomic_json_update() {
  local json_file="$1"
  shift
  
  if [[ ! -f "$json_file" ]]; then
    die "JSON file not found: $json_file"
  fi
  
  # Validate JSON first
  if ! jq empty "$json_file" 2>/dev/null; then
    die "Invalid JSON in: $json_file"
  fi
  
  local tmp_file
  tmp_file="$(mktemp -t workstation.XXXXXX)"
  
  # Apply update - pass remaining args to jq
  if ! jq "$@" "$json_file" > "$tmp_file" 2>/dev/null; then
    rm -f "$tmp_file"
    die "Failed to update JSON"
  fi
  
  # Atomic move
  mv "$tmp_file" "$json_file"
}

# Ensure git user is configured (local to repo only)
git_ensure_user() {
  if ! git config user.name >/dev/null 2>&1; then
    git config user.email "workstation@local" 2>/dev/null || true
    git config user.name "Workstation CLI" 2>/dev/null || true
  fi
  
  # Double check - if still not set, try with environment variables
  if ! git config user.name >/dev/null 2>&1; then
    export GIT_AUTHOR_NAME="Workstation CLI"
    export GIT_AUTHOR_EMAIL="workstation@local"
    export GIT_COMMITTER_NAME="Workstation CLI"
    export GIT_COMMITTER_EMAIL="workstation@local"
  fi
}

# Safe git commit (with error handling)
git_safe_commit() {
  local message="$1"
  
  git_ensure_user
  
  if ! git add -A >/dev/null 2>&1; then
    return 1
  fi
  
  if git diff --cached --quiet >/dev/null 2>&1; then
    return 0  # Nothing to commit
  fi
  
  git commit -m "$message" >/dev/null 2>&1 || return 1
}

# ============================================================================
# COMMAND: version
# ============================================================================

cmd_version() {
  cat << EOF
Workstation CLI v${VERSION}
Organization Manager for OpenClaw

Paths:
  WORKSTATION_ROOT: ${WORKSTATION_ROOT}
  OPENCLAW_HOME:    ${OPENCLAW_HOME}
EOF
}

# ============================================================================
# COMMAND: init
# ============================================================================

cmd_init() {
  local org_name="${1:-}"
  
  if [[ -z "$org_name" ]]; then
    die "Usage: workstation init <organization-name>"
  fi
  
  org_name=$(validate_id "$org_name" "organization name")
  
  local ssot_path="${WORKSTATION_ROOT}/${org_name}-SSOT"
  
  if [[ -d "$ssot_path" ]]; then
    die "Organization '$org_name' already exists at $ssot_path"
  fi
  
  log_info "Initializing Workstation for: $org_name"
  
  # Create directory structure
  mkdir -p "${ssot_path}/"{_seats,KBs,Projects,templates/seat,.claims}
  
  # Generate workstation.json
  cat > "${ssot_path}/workstation.json" << EOF
{
  "version": "${VERSION}",
  "schema": "workstation-v3",
  "organization": {
    "name": "${org_name}",
    "created_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
    "timezone": "UTC"
  },
  "seats": [],
  "kbs": [],
  "claims": []
}
EOF

  # Copy templates - try multiple locations
  local template_source=""
  
  # First try: relative to script location
  template_source="$(dirname "$(dirname "${BASH_SOURCE[0]}")")/templates/seat"
  
  # Second try: if script is in /tmp (testing), look in original location
  if [[ ! -d "$template_source" ]] && [[ "${BASH_SOURCE[0]}" == /tmp/* ]]; then
    # Try to find templates in common locations
    for try_path in "$WORKSTATION_ROOT/../workstation-cli/templates/seat" "$HOME/workstation-cli/templates/seat" "/tmp/workstation-cli/templates/seat"; do
      if [[ -d "$try_path" ]]; then
        template_source="$try_path"
        break
      fi
    done
  fi
  
  if [[ -d "$template_source" ]]; then
    cp "${template_source}/"*.md "${ssot_path}/templates/seat/" 2>/dev/null || true
    log_info "Templates copied from: $template_source"
  else
    log_warn "Templates not found, creating minimal defaults"
    # Create minimal templates
    echo "# BOOTSTRAP" > "${ssot_path}/templates/seat/BOOTSTRAP.md"
    echo "# AGENT" > "${ssot_path}/templates/seat/AGENT.md"
  fi
  
  # Create core KB
  mkdir -p "${ssot_path}/KBs/KB-Core"
  cat > "${ssot_path}/KBs/KB-Core/README.md" << EOF
# KB-Core: ${org_name}

Core Knowledge Base for ${org_name}.

## Purpose
This directory contains organizational standards, conventions, and shared knowledge.

## Structure
- \`standards/\` - Coding standards, conventions
- \`guides/\` - How-to guides and tutorials
- \`references/\` - Quick reference materials

## Usage
These files are automatically linked to all agent seats via symlinks.
EOF

  # Initialize git
  (
    cd "$ssot_path"
    git init --quiet
    
    # Create .gitignore
    cat > .gitignore << 'GITIGNORE'
# Workstation
.env
.env.local
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.swp
*~
GITIGNORE

    git add . >/dev/null 2>&1
    git_safe_commit "Initial Workstation setup for ${org_name}"
  )
  
  log_success "Workstation initialized at: ${ssot_path}"
  echo ""
  echo "Next steps:"
  echo "  cd ${ssot_path}"
  echo "  workstation seat create <name> --role <role>"
}

# ============================================================================
# COMMAND: seat create
# ============================================================================

cmd_seat_create() {
  local seat_id=""
  local role="general"
  
  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case $1 in
      --role)
        role="$2"
        shift 2
        ;;
      --help)
        echo "Usage: workstation seat create <id> [--role <role>]"
        exit 0
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        if [[ -z "$seat_id" ]]; then
          seat_id="$1"
        fi
        shift
        ;;
    esac
  done
  
  if [[ -z "$seat_id" ]]; then
    die "Usage: workstation seat create <id> [--role <role>]"
  fi
  
  seat_id=$(validate_id "$seat_id" "seat ID")
  
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found. Run 'workstation init' first."
  
  local config_file="${ssot_dir}/workstation.json"
  local org_name
  org_name=$(get_config "$ssot_dir" '.organization.name')
  
  # Check if seat already exists
  if jq -e --arg id "$seat_id" '.seats[] | select(.id == $id)' "$config_file" >/dev/null 2>&1; then
    die "Seat '$seat_id' already exists"
  fi
  
  log_info "Creating seat: $seat_id"
  
  # Create workspace
  local workspace_path="${OPENCLAW_HOME}/workspace-${seat_id}"
  mkdir -p "$workspace_path"
  
  # Copy and customize templates
  local template_dir="${ssot_dir}/templates/seat"
  local date_str
  date_str=$(date +%Y-%m-%d)
  
  if [[ -d "$template_dir" ]]; then
    for template in "$template_dir"/*.md; do
      [[ -f "$template" ]] || continue
      
      local filename
      filename=$(basename "$template")
      local dest="${workspace_path}/${filename}"
      
      # Safe sed replacement
      sed -e "s/{SEAT_ID}/$(escape_sed "$seat_id")/g" \
          -e "s/{ORG_NAME}/$(escape_sed "$org_name")/g" \
          -e "s/{DATE}/$(escape_sed "$date_str")/g" \
          -e "s/{ROLE}/$(escape_sed "$role")/g" \
          "$template" > "$dest"
    done
  fi
  
  # Create imports directory
  mkdir -p "${workspace_path}/imports"
  
  # Create backup directory
  local backup_path="${ssot_dir}/_seats/${seat_id}"
  mkdir -p "${backup_path}/snapshots"
  
  # Update workstation.json atomically
  atomic_json_update "$config_file" \
    --arg id "$seat_id" \
    --arg role "$role" \
    --arg workspace "$workspace_path" \
    --arg backup "_seats/${seat_id}" \
    --arg date "$date_str" \
    '.seats += [{
      "id": $id,
      "role": $role,
      "workspace_path": $workspace,
      "backup_path": $backup,
      "created_at": $date,
      "last_sync": null,
      "status": "inactive"
    }]'
  
  # Git commit
  (
    cd "$ssot_dir"
    git_safe_commit "Add seat: ${seat_id}"
  )
  
  log_success "Seat '${seat_id}' created"
  echo "Workspace: ${workspace_path}"
  echo "Activate with: workstation seat activate ${seat_id}"
}

# ============================================================================
# COMMAND: seat activate
# ============================================================================

cmd_seat_activate() {
  local seat_id="${1:-}"
  
  if [[ -z "$seat_id" ]]; then
    die "Usage: workstation seat activate <id>"
  fi
  
  seat_id=$(validate_id "$seat_id" "seat ID")
  
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  
  # Get workspace path from config
  local workspace_path
  workspace_path=$(get_config "$ssot_dir" --arg id "$seat_id" '.seats[] | select(.id == $id) | .workspace_path')
  
  if [[ -z "$workspace_path" || "$workspace_path" == "null" ]]; then
    die "Seat '$seat_id' not found"
  fi
  
  if [[ ! -d "$workspace_path" ]]; then
    die "Seat workspace not found: $workspace_path"
  fi
  
  log_info "Activating seat: $seat_id"
  
  # Update symlink atomically
  rm -f "${OPENCLAW_HOME}/workspace"
  ln -s "$workspace_path" "${OPENCLAW_HOME}/workspace"
  
  # Update status in config
  local config_file="${ssot_dir}/workstation.json"
  atomic_json_update "$config_file" \
    --arg id "$seat_id" \
    '.seats |= map(if .id == $id then .status = "active" else .status = "inactive" end)'
  
  # Git commit
  (
    cd "$ssot_dir"
    git_safe_commit "Activate seat: ${seat_id}"
  )
  
  log_success "Seat '${seat_id}' is now active"
  echo "Workspace: ${workspace_path}"
}

# ============================================================================
# COMMAND: seat list
# ============================================================================

cmd_seat_list() {
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  
  local config_file="${ssot_dir}/workstation.json"
  
  echo "Seats:"
  echo ""
  
  local seats
  seats=$(jq -r '.seats[] | "  \(.id) | role: \(.role) | status: \(.status // "unknown") | last sync: \(.last_sync // "never")"' "$config_file" 2>/dev/null) || true
  
  if [[ -n "$seats" ]]; then
    printf '%s\n' "$seats"
  else
    echo "  No seats found"
  fi
  
  echo ""
  echo "Active workspace:"
  if [[ -L "${OPENCLAW_HOME}/workspace" ]]; then
    local target
    target=$(readlink "${OPENCLAW_HOME}/workspace")
    echo "  $target"
  else
    echo "  None"
  fi
}

# ============================================================================
# COMMAND: seat sync
# ============================================================================

cmd_seat_sync() {
  local seat_id="${1:-}"
  
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  local config_file="${ssot_dir}/workstation.json"
  
  if [[ -n "$seat_id" ]]; then
    seat_id=$(validate_id "$seat_id" "seat ID")
    sync_single_seat "$ssot_dir" "$seat_id"
  else
    log_info "Syncing all seats..."
    local seats
    seats=$(jq -r '.seats[].id' "$config_file" 2>/dev/null) || true
    
    for id in $seats; do
      sync_single_seat "$ssot_dir" "$id" || log_warn "Failed to sync: $id"
    done
  fi
}

sync_single_seat() {
  local ssot_dir="$1"
  local seat_id="$2"
  local config_file="${ssot_dir}/workstation.json"
  
  local workspace_path
  workspace_path=$(get_config "$ssot_dir" --arg id "$seat_id" '.seats[] | select(.id == $id) | .workspace_path')
  
  if [[ -z "$workspace_path" || "$workspace_path" == "null" ]]; then
    log_warn "Seat '$seat_id' not found in config"
    return 1
  fi
  
  if [[ ! -d "$workspace_path" ]]; then
    log_warn "Seat '$seat_id': workspace not found"
    return 1
  fi
  
  log_info "Syncing: $seat_id"
  
  # Create snapshot
  local backup_path="${ssot_dir}/_seats/${seat_id}"
  mkdir -p "${backup_path}/snapshots"
  
  local snapshot
  snapshot="${backup_path}/snapshots/$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$snapshot"
  
  # Backup critical files safely
  local files=("AGENT.md" "SOUL.md" "MEMORY.md" "TOOLS.md" "IDENTITY.md" "HEARTBEAT.md")
  for file in "${files[@]}"; do
    if [[ -f "${workspace_path}/${file}" ]]; then
      cp "${workspace_path}/${file}" "${snapshot}/"
    fi
  done
  
  # Backup memory directory
  if [[ -d "${workspace_path}/memory" ]]; then
    cp -r "${workspace_path}/memory" "${snapshot}/"
  fi
  
  # Cleanup old snapshots (keep last 20)
  find "${backup_path}/snapshots" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' 2>/dev/null | \
    sort -r -n | \
    tail -n +21 | \
    cut -d' ' -f2- | \
    xargs -r rm -rf 2>/dev/null || true
  
  # Sync KBs via symlinks
  local kbs
  kbs=$(jq -r --arg id "$seat_id" '.seats[] | select(.id == $id) | .kbs[]?' "$config_file" 2>/dev/null) || true
  
  if [[ -n "$kbs" && "$kbs" != "null" ]]; then
    local imports_dir="${workspace_path}/imports"
    mkdir -p "$imports_dir"
    
    for kb in $kbs; do
      local kb_path="${ssot_dir}/KBs/${kb}"
      local link_path="${imports_dir}/${kb}"
      
      rm -f "$link_path"
      if [[ -d "$kb_path" ]]; then
        ln -sf "$kb_path" "$link_path"
      fi
    done
  fi
  
  # Update timestamp
  local date_str
  date_str=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  
  atomic_json_update "$config_file" \
    --arg id "$seat_id" \
    --arg date "$date_str" \
    '.seats |= map(if .id == $id then .last_sync = $date else . end)'
  
  # Git commit
  (
    cd "$ssot_dir"
    git_safe_commit "Sync seat: ${seat_id}"
  )
  
  log_success "Seat '${seat_id}' synced"
}

# ============================================================================
# COMMAND: kb add
# ============================================================================

cmd_kb_add() {
  local kb_name="${1:-}"
  local repo="${2:-}"
  
  if [[ -z "$kb_name" || -z "$repo" ]]; then
    die "Usage: workstation kb add <name> <repo-url>"
  fi
  
  kb_name=$(validate_id "$kb_name" "KB name")
  repo=$(validate_git_url "$repo")
  
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  
  local kb_path="${ssot_dir}/KBs/${kb_name}"
  
  if [[ -d "$kb_path" ]]; then
    die "KB '$kb_name' already exists"
  fi
  
  log_info "Adding KB: $kb_name"
  
  # Clone with timeout and error handling
  if ! timeout 60 git clone "$repo" "$kb_path" 2>&1; then
    die "Failed to clone repository"
  fi
  
  # Update config
  local config_file="${ssot_dir}/workstation.json"
  atomic_json_update "$config_file" \
    --arg name "$kb_name" \
    --arg repo "$repo" \
    '.kbs += [{"name": $name, "repo": $repo, "added_at": now | todate}]'
  
  # Git commit
  (
    cd "$ssot_dir"
    git_safe_commit "Add KB: ${kb_name}"
  )
  
  log_success "KB '${kb_name}' added"
}

# ============================================================================
# COMMAND: kb update
# ============================================================================

cmd_kb_update() {
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  
  log_info "Updating KBs..."
  
  local updated=0
  for kb_dir in "${ssot_dir}/KBs/"*/; do
    [[ -d "${kb_dir}/.git" ]] || continue
    
    local kb_name
    kb_name=$(basename "$kb_dir")
    
    log_info "  Updating: $kb_name"
    
    if timeout 60 git -C "$kb_dir" pull --quiet 2>&1; then
      ((updated++)) || true
    else
      log_warn "    Failed to update: $kb_name"
    fi
  done
  
  log_success "Updated ${updated} KB(s)"
  
  # Resync seats
  cmd_seat_sync
}

# ============================================================================
# COMMAND: kb list
# ============================================================================

cmd_kb_list() {
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  
  echo "Knowledge Bases:"
  echo ""
  
  local kbs
  kbs=$(jq -r '.kbs[] | "  \(.name) | \(.repo)"' "${ssot_dir}/workstation.json" 2>/dev/null) || true
  
  if [[ -n "$kbs" ]]; then
    printf '%s\n' "$kbs"
  else
    echo "  No KBs found"
  fi
}

# ============================================================================
# COMMAND: backup
# ============================================================================

cmd_backup() {
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  
  log_info "Running full backup..."
  
  local seats
  seats=$(jq -r '.seats[].id' "${ssot_dir}/workstation.json" 2>/dev/null) || true
  
  for seat_id in $seats; do
    local workspace_path
    workspace_path=$(get_config "$ssot_dir" --arg id "$seat_id" '.seats[] | select(.id == $id) | .workspace_path')
    
    [[ -d "$workspace_path" ]] || continue
    
    log_info "  Backing up: $seat_id"
    
    local backup_path="${ssot_dir}/_seats/${seat_id}"
    mkdir -p "${backup_path}/archives"
    
    local archive
    archive="${backup_path}/archives/backup-$(date +%Y%m%d-%H%M%S).tar.gz"
    
    # Create archive with explicit file list
    tar -czf "$archive" -C "$workspace_path" \
      --exclude='.git' \
      AGENT.md SOUL.md MEMORY.md TOOLS.md IDENTITY.md HEARTBEAT.md memory/ 2>/dev/null || true
  done
  
  # Commit SSOT
  (
    cd "$ssot_dir"
    git_safe_commit "Backup: $(date +%Y-%m-%d %H:%M)"
  )
  
  log_success "Backup complete"
}

# ============================================================================
# COMMAND: status
# ============================================================================

cmd_status() {
  local ssot_dir
  if ! ssot_dir=$(find_ssot 2>/dev/null); then
    echo "Not in a workstation directory"
    exit 1
  fi
  
  local config_file="${ssot_dir}/workstation.json"
  local org_name
  org_name=$(get_config "$ssot_dir" '.organization.name')
  
  echo "=== Workstation Status ==="
  echo "Organization: $org_name"
  echo "SSOT: $ssot_dir"
  echo ""
  
  echo "Seats:"
  local seats
  seats=$(jq -r '.seats[] | "  \(.id) (\(.role)) - \(.status // "unknown")"' "$config_file" 2>/dev/null) || true
  if [[ -n "$seats" ]]; then
    printf '%s\n' "$seats"
  else
    echo "  None"
  fi
  
  echo ""
  echo "Active workspace:"
  if [[ -L "${OPENCLAW_HOME}/workspace" ]]; then
    readlink "${OPENCLAW_HOME}/workspace"
  else
    echo "  None"
  fi
  
  echo ""
  echo "KBs:"
  local kbs
  kbs=$(jq -r '.kbs[] | "  \(.name)"' "$config_file" 2>/dev/null) || true
  if [[ -n "$kbs" ]]; then
    printf '%s\n' "$kbs"
  else
    echo "  None"
  fi
}

# ============================================================================
# COMMAND: doctor
# ============================================================================

cmd_doctor() {
  echo "=== Workstation Doctor ==="
  echo ""
  
  local errors=0
  
  # Check dependencies
  echo -n "Checking jq... "
  if command -v jq >/dev/null 2>&1; then
    log_success "found"
  else
    log_error "missing (install: apt-get install jq / brew install jq)"
    ((errors++))
  fi
  
  echo -n "Checking git... "
  if command -v git >/dev/null 2>&1; then
    log_success "found"
  else
    log_error "missing"
    ((errors++))
  fi
  
  echo ""
  
  # Check directories
  echo -n "WORKSTATION_ROOT (${WORKSTATION_ROOT})... "
  if [[ -d "$WORKSTATION_ROOT" ]]; then
    log_success "exists"
  else
    log_warn "does not exist (will be created on init)"
  fi
  
  echo -n "OPENCLAW_HOME (${OPENCLAW_HOME})... "
  if [[ -d "$OPENCLAW_HOME" ]]; then
    log_success "exists"
  else
    log_warn "does not exist"
  fi
  
  echo ""
  
  # Check SSOT if in one
  if ssot_dir=$(find_ssot 2>/dev/null); then
    log_success "Found SSOT: $ssot_dir"
    
    echo -n "Validating workstation.json... "
    if jq empty "${ssot_dir}/workstation.json" 2>/dev/null; then
      log_success "valid JSON"
    else
      log_error "invalid JSON"
      ((errors++))
    fi
  fi
  
  echo ""
  
  if [[ $errors -eq 0 ]]; then
    log_success "All checks passed"
  else
    log_error "${errors} error(s) found"
    exit 1
  fi
}

# ============================================================================
# COMMAND: claim (File locking for multi-agent coordination)
# ============================================================================

cmd_claim() {
  local file_path="${1:-}"
  local ttl="30m"
  local reason=""
  
  # Parse options
  while [[ $# -gt 1 ]]; do
    case $2 in
      --ttl) ttl="$3"; shift 2 ;;
      --reason) reason="$3"; shift 2 ;;
      *) shift ;;
    esac
  done
  
  if [[ -z "$file_path" ]]; then
    die "Usage: workstation claim <file> [--ttl <duration>] [--reason <text>]"
  fi
  
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  
  local config_file="${ssot_dir}/workstation.json"
  local active_seat
  active_seat=$(jq -r '.seats[] | select(.status == "active") | .id' "$config_file" 2>/dev/null) || true
  
  if [[ -z "$active_seat" ]]; then
    die "No active seat. Run 'workstation seat activate <id>' first."
  fi
  
  # Check if already claimed (by anyone, including self)
  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  
  local existing_claim
  existing_claim=$(jq -r --arg file "$file_path" --arg now "$now" \
    '.claims[]? | select(.file == $file and .expires >= $now) | .seat' \
    "$config_file" 2>/dev/null) || true
  
  if [[ -n "$existing_claim" ]]; then
    if [[ "$existing_claim" == "$active_seat" ]]; then
      die "File already claimed by you. Release it first: workstation release $file_path"
    else
      die "File already claimed by: $existing_claim"
    fi
  fi
  
  # Parse TTL
  local ttl_minutes=30
  if [[ "$ttl" =~ ^([0-9]+)m$ ]]; then
    ttl_minutes="${BASH_REMATCH[1]}"
  elif [[ "$ttl" =~ ^([0-9]+)h$ ]]; then
    ttl_minutes=$((BASH_REMATCH[1] * 60))
  elif [[ "$ttl" =~ ^([0-9]+)$ ]]; then
    ttl_minutes="${BASH_REMATCH[1]}"
  fi
  
  # Calculate expiration (portable, works on both Linux and macOS)
  local expires
  if date -u -d "+${ttl_minutes} minutes" +%Y-%m-%dT%H:%M:%SZ >/dev/null 2>&1; then
    # GNU date (Linux)
    expires=$(date -u -d "+${ttl_minutes} minutes" +%Y-%m-%dT%H:%M:%SZ)
  else
    # BSD date (macOS)
    expires=$(date -u -v+"${ttl_minutes}"M +%Y-%m-%dT%H:%M:%SZ)
  fi
  
  # Add claim
  atomic_json_update "$config_file" \
    --arg file "$file_path" \
    --arg seat "$active_seat" \
    --arg expires "$expires" \
    --arg reason "$reason" \
    '.claims += [{"file": $file, "seat": $seat, "expires": $expires, "reason": $reason}]'
  
  (
    cd "$ssot_dir"
    git_safe_commit "Claim: ${file_path} by ${active_seat}"
  )
  
  log_success "Claimed: $file_path"
  echo "Expires: $expires"
  [[ -n "$reason" ]] && echo "Reason: $reason"
}

# ============================================================================
# COMMAND: claims (List active claims)
# ============================================================================

cmd_claims() {
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  local config_file="${ssot_dir}/workstation.json"
  
  echo "Active claims:"
  echo ""
  
  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  
  local claims
  claims=$(jq -r --arg now "$now" \
    '.claims[]? | select(.expires >= $now) | "  \(.file) | claimed by: \(.seat) | expires: \(.expires)"' \
    "$config_file" 2>/dev/null) || true
  
  if [[ -n "$claims" ]]; then
    printf '%s\n' "$claims"
  else
    echo "  No active claims"
  fi
}

# ============================================================================
# COMMAND: release (Release a claim)
# ============================================================================

cmd_release() {
  local file_path="${1:-}"
  
  if [[ -z "$file_path" ]]; then
    die "Usage: workstation release <file>"
  fi
  
  local ssot_dir
  ssot_dir=$(find_ssot) || die "No workstation.json found"
  local config_file="${ssot_dir}/workstation.json"
  
  atomic_json_update "$config_file" \
    --arg file "$file_path" \
    'del(.claims[]? | select(.file == $file))'
  
  (
    cd "$ssot_dir"
    git_safe_commit "Release: ${file_path}"
  )
  
  log_success "Released: $file_path"
}

# ============================================================================
# HELP
# ============================================================================

cmd_help() {
  cat << 'EOF'
Workstation CLI - Organization Manager for OpenClaw

USAGE:
  workstation <command> [options]

COMMANDS:
  General:
    version              Show version information
    doctor               Check installation and dependencies
    help                 Show this help message
    status               Show current status

  Organization:
    init <name>          Initialize new organization SSOT

  Seats (Agents):
    seat create <id> [--role <role>]
                         Create new agent seat
    seat activate <id>   Activate seat (switch workspace)
    seat list            List all seats
    seat sync [id]       Sync seat(s) with SSOT

  Knowledge Bases:
    kb add <name> <repo>  Add Knowledge Base from git
    kb update            Update all KBs via git pull
    kb list              List all KBs

  Multi-Agent Coordination:
    claim <file> [--ttl <m|h>] [--reason <text>]
                         Claim a file for exclusive editing
    claims               List active claims
    release <file>       Release a claim

  Maintenance:
    backup               Full backup of all seats

ENVIRONMENT:
  WORKSTATION_ROOT       Root directory (default: ~/Workstation)
  OPENCLAW_HOME          OpenClaw home (default: ~/.openclaw)

EXAMPLES:
  # Initialize organization
  workstation init MyCompany

  # Create and activate seat
  cd ~/Workstation/MyCompany-SSOT
  workstation seat create developer --role backend
  workstation seat activate developer

  # Claim file for editing
  workstation claim src/main.py --ttl 45m --reason "Refactoring"
  workstation claims
  workstation release src/main.py

  # Add KB and sync
  workstation kb add standards https://github.com/org/standards.git
  workstation seat sync

  # Full backup
  workstation backup
EOF
}

# ============================================================================
# MAIN
# ============================================================================

main() {
  # Check for jq
  if ! command -v jq >/dev/null 2>&1; then
    die "jq is required. Install: sudo apt-get install jq (or equivalent)"
  fi
  
  local cmd="${1:-help}"
  shift || true
  
  case $cmd in
    version|-v|--version) cmd_version "$@" ;;
    help|-h|--help) cmd_help ;;
    doctor) cmd_doctor "$@" ;;
    status) cmd_status "$@" ;;
    init) cmd_init "$@" ;;
    
    seat)
      local sub="${1:-help}"
      shift || true
      case $sub in
        create) cmd_seat_create "$@" ;;
        activate) cmd_seat_activate "$@" ;;
        list) cmd_seat_list "$@" ;;
        sync) cmd_seat_sync "$@" ;;
        *) cmd_help ;;
      esac
      ;;
    
    kb)
      local sub="${1:-help}"
      shift || true
      case $sub in
        add) cmd_kb_add "$@" ;;
        update) cmd_kb_update "$@" ;;
        list) cmd_kb_list "$@" ;;
        *) cmd_help ;;
      esac
      ;;
    
    backup) cmd_backup "$@" ;;
    
    claim) cmd_claim "$@" ;;
    claims) cmd_claims "$@" ;;
    release) cmd_release "$@" ;;
    
    *) 
      log_error "Unknown command: $cmd"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
